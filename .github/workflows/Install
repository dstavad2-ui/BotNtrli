name: Run Naturlig AI Bot

on:
  workflow_dispatch:

jobs:
  run-bot:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v2

      - name: Set up Python
        uses: actions/setup-python@v2
        with:
          python-version: '3.10'

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install flask requests pyngrok

      - name: Run bot
        run: |
          python bot/bot_api.py &
          python bot/bot_handler.py &
          sleep 5
          curl -X POST "https://api.telegram.org/bot8654351542:AAHgwkZhGyichKIS1APditSo-kVo1liLy9I/setWebhook?url=$(curl -s http://localhost:4040/api/tunnels | jq -r '.tunnels[0].public_url')/bot/webhook"
        env:
          PYTHONUNBUFFERED: 1
